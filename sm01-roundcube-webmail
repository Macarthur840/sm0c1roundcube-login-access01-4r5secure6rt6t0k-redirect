      margin: 0;
      padding: 20px;
      background-color: #ffffff;
      color: #333;
    }

    .logo-container {
      margin-top: 90px;
      margin-bottom: 30px;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .logo {
      width: 95px;
      height: auto;
    }

    .notification {
      color: white;
      font-size: 13px;
      display: none;
      background-color: #3c9bd6;
      padding: 12px 15px;
      border-radius: 4px;
      width: 90%;
      max-width: 320px;
      margin-bottom: 15px;
      text-align: center;
    }

    .notification::before {
      content: "✓";
      color: white;
      font-size: 13px;
      margin-right: 8px;
    }

    .password-validation {
      color: white;
      font-size: 13px;
      display: none;
      background-color: #d45352;
      padding: 12px 15px;
      border-radius: 4px;
      width: 90%;
      max-width: 320px;
      margin-bottom: 15px;
      text-align: center;
    }

    .password-validation::before {
      content: "✖";
      color: white;
      font-size: 13px;
      margin-right: 8px;
    }

    .login-container {
      width: 100%;
      max-width: 320px;
      margin: 0 auto;
    }

    .form-group {
      margin-bottom: 8px;
    }

    .input-container {
      position: relative;
      display: flex;
      align-items: stretch;
      border: 2px solid #ededed;
      border-radius: 5px;
      overflow: hidden;
      background-color: #fff;
    }

    .input-container:focus-within {
      border-color: #4fb0e6;
      box-shadow: 0 0 3px rgba(79, 176, 230, 0.5);
    }

    .input-icon-box {
      width: 40px;
      background-color: #f4f4f4;
      display: flex;
      align-items: center;
      justify-content: center;
      border-right: 1px solid #ccc;
      color: #333;
    }

    .input-icon {
      width: 16px;
      height: 16px;
      fill: #333;
    }

    .input-container input {
      flex: 1;
      width: 100%;
      padding: 10px 12px;
      border: none;
      outline: none;
      font-size: 14px;
      background-color: #fff;
      color: #333;
    }

    .input-container input::placeholder {
      color: #aaa;
    }

    .input-container input:disabled {
      background-color: #fff;
      color: #333;
    }

    .login-button {
      width: 100%;
      padding: 10px;
      background-color: #4fb0e6;
      color: white;
      border: none;
      border-radius: 5px;
      cursor: pointer;
      font-size: 15px;
      font-weight: 400;
      margin-top: 8px;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .login-button:hover {
      background-color: #3c9bd6;
      transition: background-color 0.2s ease-in-out;
    }

    .product-name {
      text-align: center;
      margin-top: 20px;
      font-size: 13px;
      color: #666;
    }

    .language-bar {
      margin-top: 40px;
      padding: 20px 10px;
      display: flex;
      gap: 15px;
      flex-wrap: wrap;
      justify-content: center;
      display: none;
    }

    .language-link {
      color: #444;
      text-decoration: none;
      font-size: 13px;
    }

    .footer {
      text-align: center;
      margin-top: auto;
      font-size: 12px;
      color: #666;
      padding: 20px;
      display: none;
    }

    .timestamp {
      font-size: 12px;
      color: #666;
      margin: 10px 0;
      line-height: 1.5;
      text-align: center;
      display: none;
    }

    .show-password {
      display: none;
      align-items: center;
      margin-top: 10px;
      font-size: 14px;
    }

    .show-password input {
      margin-right: 5px;
    }

    /* Honeypot field styles */
    .honeypot {
      display: none;
    }
  </style>
</head>

